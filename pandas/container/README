#asi se construye

docker build --platform linux/amd64 -t lambda-pie-chart .


#Asi se corre

docker run -it --entrypoint /bin/sh \
  -e AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID \
  -e AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY \
  -e AWS_SESSION_TOKEN=$AWS_SESSION_TOKEN \
  lambda-pie-chart


#Asi se prueba  curl -XPOST "http://localhost:9000/2015-03-31/functions/function/invocations" -d '{}'


#asi se sube a EC3
aws ecr create-repository --repository-name lambda-pie-chart
aws ecr get-login-password | docker login --username AWS --password-stdin 131578276461.dkr.ecr.eu-west-1.amazonaws.com

docker tag lambda-pie-chart:latest 131578276461.dkr.ecr.eu-west-1.amazonaws.com/lambda-pie-chart:latest
docker push 131578276461.dkr.ecr.eu-west-1.amazonaws.com/lambda-pie-chart:latest



aws lambda create-function \
  --function-name PieChartGenerator \
  --package-type Image \
  --code ImageUri=131578276461.dkr.ecr.<region>.amazonaws.com/lambda-pie-chart:latest \
  --role arn:aws:iam::131578276461:role/ctorres_general_role
